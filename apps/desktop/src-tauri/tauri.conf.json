{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timer Stacks",
  "version": "0.1.0",
  "identifier": "com.timerstacks.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Timer Stacks",
        "width": 1100,
        "height": 760,
        "minWidth": 780,
        "minHeight": 560,
        "decorations": true,
        "transparent": false
      
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
